---
import type { RioFuegoContext } from '../../layouts/RioFuegoLayout.astro';

interface Props {
  lang: 'en' | 'es';
  context: RioFuegoContext;
}

const { context } = Astro.props;
const whatsappUrl = `https://wa.me/${context.contactCTA.whatsappNumber.replace('+', '')}?text=${encodeURIComponent(context.contactCTA.whatsappMessage)}`;
---

<div class="fixed-cta-wrapper" style="position: fixed; bottom: 20px; left: 20px; right: 20px; z-index: 100; pointer-events: none; display: none;">
  <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" style="display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; padding: 14px 20px; background: #3D5A3E; color: var(--crema); font-family: var(--sans); font-weight: 500; font-size: 15px; border-radius: 4px; box-shadow: 0 4px 16px rgba(0,0,0,0.25); text-decoration: none; pointer-events: auto; transition: transform 0.25s, background-color 0.25s;">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
      <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.73-1.45L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.965C16.528 2.062 14.076.993 11.51.991c-5.441 0-9.864 4.37-9.868 9.8-.001 1.764.475 3.486 1.38 5.01l-1.029 3.756 3.845-.989c1.5.875 3.033 1.336 4.619 1.336zm11.368-7.793c-.3-.15-1.774-.875-2.048-.974-.275-.1-.475-.15-.674.15-.2.3-.775.974-.95 1.174-.175.2-.35.225-.65.075-.3-.15-1.265-.467-2.41-1.485-.89-.795-1.49-1.778-1.665-2.078-.175-.3-.018-.462.13-.61.135-.133.3-.35.45-.525.15-.175.2-.3.3-.5s.05-.375-.025-.525C10.1 6.956 9.4 5.23 9.1 4.53c-.292-.707-.59-.61-.81-.622-.21-.01-.45-.01-.69-.01-.24 0-.63.09-1.03.525-.4.438-1.525 1.492-1.525 3.639 0 2.148 1.562 4.22 1.782 4.52.22.3 3.076 4.697 7.452 6.59 1.042.451 1.854.72 2.487.921 1.046.333 1.999.286 2.753.173.84-.127 2.583-1.055 2.946-2.075.362-1.02.362-1.895.253-2.075-.11-.18-.31-.28-.61-.43z"/>
    </svg>
    <span>{context.contactCTA.label}</span>
  </a>
</div>

<style>
  @media (max-width: 900px) {
    .fixed-cta-wrapper {
      display: block !important;
    }
  }
  .fixed-cta-wrapper {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  /* Oculto mientras el CTA del hero está en pantalla — evita el botón duplicado */
  .fixed-cta-wrapper.cta-hidden {
    opacity: 0;
    transform: translateY(12px);
    pointer-events: none;
  }
  .fixed-cta-wrapper.cta-hidden a {
    pointer-events: none;
  }
  .fixed-cta-wrapper a:hover {
    background-color: var(--barro) !important;
    transform: translateY(-2px);
  }
</style>

<script>
  // Muestra el CTA fijo solo cuando el hero (con su propio botón) ya no es visible.
  const wrapper = document.querySelector('.fixed-cta-wrapper');
  const hero = document.querySelector('.rf-hero');

  if (wrapper && hero && 'IntersectionObserver' in window) {
    wrapper.classList.add('cta-hidden');
    const io = new IntersectionObserver(([entry]) => {
      wrapper.classList.toggle('cta-hidden', entry.isIntersecting);
    }, { threshold: 0.2 });
    io.observe(hero);
  }
</script>
