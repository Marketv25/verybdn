---
import { Image } from 'astro:assets';
import imgHero from '../../assets/img/rio-y-fuego-hero.png';
import imgRiver from '../../assets/img/rio-y-fuego-river.png';
import imgSauna from '../../assets/img/rio-y-fuego-sauna.png';
import imgHorno from '../../assets/img/horno-lodge.png';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;

const images = [
  { src: imgHero, alt: lang === 'en' ? 'River next to the lodge terrace' : 'Río junto a la terraza del lodge' },
  { src: imgRiver, alt: lang === 'en' ? 'Trail through the forest to the lodge' : 'Sendero entre el bosque hacia el lodge' },
  { src: imgSauna, alt: lang === 'en' ? 'El Refugio terrace with mountain view' : 'Terraza de El Refugio con vista a la sierra' },
  { src: imgHorno, alt: lang === 'en' ? 'Bonfire lit on the way down to the river' : 'Fogata encendida en la bajada al río' }
];
---

<section id={lang === 'en' ? 'gallery' : 'galeria'} class="wrap reveal" style="padding: 90px 28px;">
  <div class="sec-head" style="margin-bottom: 44px; max-width: 65ch;">
    <span class="eyebrow">{lang === 'en' ? 'Gallery' : 'Galería'}</span>
    <h2 style="font-family: var(--serif); font-style: normal; font-weight: 400; font-size: clamp(28px, 4vw, 42px); line-height: 1.1; margin-top: 12px;">
      {lang === 'en' ? 'Gallery' : 'Galería'}
    </h2>
    <p class="lede" style="font-family: var(--sans); font-weight: 300; font-size: 18px; color: var(--sombra); margin-top: 16px; line-height: 1.6;">
      {lang === 'en' ? 'The place, as it is.' : 'El lugar, tal como es.'}
    </p>
  </div>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px;">
    {images.map((img, idx) => (
      <div style="position: relative; overflow: hidden; border-radius: 4px; border: 1px solid var(--borde); aspect-ratio: 4/3; cursor: pointer; transition: transform 0.25s;">
        <Image 
          src={img.src} 
          alt={img.alt} 
          style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease;" 
          width={600}
          height={450}
          loading="lazy"
          class="gal-img"
        />
        <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(26,24,20,0) 50%, rgba(26,24,20,0.65) 100%); display: flex; align-items: flex-end; padding: 16px; opacity: 0; transition: opacity 0.3s;">
          <span style="color: var(--crema); font-family: var(--sans); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase;">
            {img.alt}
          </span>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  div:hover .gal-img {
    transform: scale(1.04);
  }
  div:hover div {
    opacity: 1 !important;
  }
</style>
