---
interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;

const includes = lang === 'en'
  ? [
      'Nightly bonfire, part of the stay',
      'Direct river access',
      'Wifi in common areas'
    ]
  : [
      'Fogata nocturna, todas las noches, parte de la estadía',
      'Acceso directo al río',
      'Wifi en áreas comunes'
    ];

const excludes = lang === 'en'
  ? [
      'Sauna (additional reservation)',
      'Wood-fired oven (advance notice, nearly three hours)',
      'Breakfast (extra cost, or nearby restaurant recommendations)',
      'Organized activities or agenda',
      'Wifi in the rooms'
    ]
  : [
      'Sauna (reserva adicional)',
      'Horno de leña (avisar con tiempo, tarda casi tres horas)',
      'Desayuno (costo adicional, o recomendación de restaurantes cercanos)',
      'Actividades organizadas o agenda',
      'Wifi en las habitaciones'
    ];
---

<section id={lang === 'en' ? 'includes' : 'incluye'} class="wrap reveal" style="padding: 90px 28px;">
  <div class="sec-head" style="margin-bottom: 56px; max-width: 65ch;">
    <span class="eyebrow">{lang === 'en' ? 'No fine print' : 'Sin letra pequeña'}</span>
    <h2 style="font-family: var(--serif); font-style: normal; font-weight: 400; font-size: clamp(28px, 4vw, 42px); line-height: 1.1; margin-top: 12px;">
      {lang === 'en' ? "What's included, what's not" : 'Lo que incluye, lo que no'}
    </h2>
    <p class="lede" style="font-family: var(--sans); font-weight: 300; font-size: 18px; color: var(--sombra); margin-top: 16px; line-height: 1.6;">
      {lang === 'en' ? 'Everything said before you book.' : 'Todo dicho antes de reservar.'}
    </p>
  </div>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 40px;">
    {/* Includes */}
    <div style="background: rgba(61, 90, 62, 0.05); border: 1.5px solid rgba(61, 90, 62, 0.2); border-radius: 4px; padding: 40px 32px;">
      <h3 style="font-family: var(--serif); font-style: italic; font-weight: 400; font-size: 26px; color: var(--selva); border-bottom: 1px solid rgba(61, 90, 62, 0.15); padding-bottom: 12px; margin-bottom: 24px; display: flex; align-items: center; gap: 8px;">
        <span style="font-size: 18px;">✓</span> {lang === 'en' ? 'What is Included' : 'Qué Incluye'}
      </h3>
      <ul style="padding-left: 20px; font-family: var(--sans); font-weight: 300; font-size: 15px; color: var(--tierra); display: flex; flex-direction: column; gap: 12px; line-height: 1.6;">
        {includes.map(item => <li>{item}</li>)}
      </ul>
    </div>

    {/* Excludes */}
    <div style="background: rgba(155, 107, 58, 0.05); border: 1.5px solid rgba(155, 107, 58, 0.2); border-radius: 4px; padding: 40px 32px;">
      <h3 style="font-family: var(--serif); font-style: italic; font-weight: 400; font-size: 26px; color: var(--barro); border-bottom: 1px solid rgba(155, 107, 58, 0.15); padding-bottom: 12px; margin-bottom: 24px; display: flex; align-items: center; gap: 8px;">
        <span style="font-size: 18px;">✗</span> {lang === 'en' ? 'What is NOT Included' : 'Qué NO Incluye'}
      </h3>
      <ul style="padding-left: 20px; font-family: var(--sans); font-weight: 300; font-size: 15px; color: var(--tierra); display: flex; flex-direction: column; gap: 12px; line-height: 1.6;">
        {excludes.map(item => <li>{item}</li>)}
      </ul>
    </div>
  </div>
</section>
