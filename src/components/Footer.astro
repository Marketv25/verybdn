---
interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div class="foot-brand">
        <span class="logo"><span class="v">very</span><span class="b">bdn</span></span>
        {lang === 'en' ? (
          <p>Applied knowledge for Colombia's Caribbean coast, written from inside it. Territory as context, narrative as tool, hospitality as real practice.</p>
        ) : (
          <p>Conocimiento aplicado sobre la costa Caribe de Colombia, escrito desde adentro. Territorio como contexto, narrativa como herramienta, hospitalidad como práctica real.</p>
        )}
      </div>
      <div class="foot-col">
        {lang === 'en' ? (
          <>
            <h4>Minca guides</h4>
            <a href="/minca/how-to-get-to-minca/">How to get to Minca</a>
          </>
        ) : (
          <>
            <h4>Guías de Minca</h4>
            <a href="/es/minca/como-llegar-a-minca/">Cómo llegar a Minca</a>
          </>
        )}
      </div>
      <div class="foot-col">
        <h4>verybdn</h4>
        {lang === 'en' ? (
          <>
            <a href="#territorio">The coast</a>
            <a href="#como">How it works</a>
            <a href="#lista">The list</a>
            <a href="#">Substack · turismo y territorio</a>
          </>
        ) : (
          <>
            <a href="#territorio">La costa</a>
            <a href="#como">Cómo funciona</a>
            <a href="#lista">La lista</a>
            <a href="#">Substack · turismo y territorio</a>
          </>
        )}
      </div>
    </div>
    <div class="foot-bottom">
      {lang === 'en' ? (
        <p>© {currentYear} verybdn · by Honey, Minca, Colombia</p>
      ) : (
        <p>© {currentYear} verybdn · por Honey, Minca, Colombia</p>
      )}
      <span class="tag">turismo · territorio · narrativa</span>
    </div>
  </div>
</footer>
