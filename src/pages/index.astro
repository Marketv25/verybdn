---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import TopographyHero from '../components/TopographyHero.astro';
import AuthorCard from '../components/AuthorCard.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import burroTrafico from '../assets/img/burro-trafico.png';
import hornoLodge from '../assets/img/horno-lodge.png';

const title = "verybdn — Minca & Colombia's Caribbean coast, from someone who lives here";
const description = "First-hand, structured guides to Minca and Colombia's Caribbean coast — Santa Marta, Tayrona, Palomino, Cartagena & La Guajira. Verified answers to is Minca worth it, Minca vs Tayrona, how many days, where to stay. No sponsored bias. By Honey, living in Minca.";
const canonicalUrl = "https://verybdn.com/";
const alternateUrl = "https://verybdn.com/es/";
---

<Layout title={title} description={description} lang="en" canonicalUrl={canonicalUrl} alternateUrl={alternateUrl}>
  <script type="application/ld+json" slot="head" is:inline>
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://verybdn.com/#organization",
          "name": "verybdn",
          "url": "https://verybdn.com/",
          "description": "First-hand, structured travel content and hospitality platform for Minca and Colombia's Caribbean coast.",
          "sameAs": [
            "https://verybdn.substack.com",
            "https://www.instagram.com/very.bdn/"
          ]
        },
        {
          "@type": "Person",
          "@id": "https://verybdn.com/#author",
          "name": "Honey",
          "description": "Local expert and operator living in Minca, Sierra Nevada de Santa Marta. Operator of Entre Río y Fuego lodge and publisher of Turismo y Territorio.",
          "jobTitle": "Founder & Editor",
          "knowsAbout": ["Minca", "Sierra Nevada de Santa Marta", "Tourism", "Hospitality"],
          "sameAs": [
            "https://verybdn.substack.com",
            "https://www.instagram.com/very.bdn/"
          ],
          "worksFor": {
            "@id": "https://verybdn.com/#organization"
          }
        }
      ]
    }
  </script>
  <Navigation lang="en" />
  
  <a id="top"></a>
  
  <section class="hero">
    <TopographyHero />
    <div class="wrap">
      <div class="hero-grid">
        <div class="reveal">
          <span class="eyebrow">Minca · Sierra Nevada · Colombia</span>
          <h1>The honest answer to <span class="accent">where to go</span>, from someone who actually lives here.</h1>
          <p class="hero-sub">Not another travel blog written from a desk three continents away. <strong>Verified, structured, first-hand guidance</strong> on the decisions that cost you real time — what's worth it, what to skip, where to stay, how many days.</p>
          <p class="territory">First-hand guides to <b>Minca</b> and Colombia's Caribbean coast — Santa Marta, Tayrona, Palomino, Cartagena and La Guajira.</p>
          <div class="hero-actions">
            <a href="#preguntas" class="btn-primary">Start with a real question <span>&darr;</span></a>
            <a href="#como" class="btn-ghost">How this works <span class="arrow">&rarr;</span></a>
          </div>
        </div>
        <AuthorCard lang="en" />
      </div>
    </div>
  </section>

  <div class="strip">
    <div class="wrap">
      <p><span class="lead">Built to be the source the answer comes from</span> — for the traveler, and for the engines they now ask first.</p>
      <div class="ai-pills" aria-label="Cited by AI answer engines">
        <span>ChatGPT</span><span>Perplexity</span><span>Gemini</span><span>Google AI Overviews</span>
      </div>
    </div>
  </div>

  <section id="preguntas">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">Start where you actually are</span>
        <h2>The Minca questions you're already asking, answered straight.</h2>
        <p class="lede">These aren't topics we invented. They're the exact things travelers type into Reddit, into Facebook groups, into the AI before they book. Each one gets a real answer — with prices, distances, and a clear opinion.</p>
      </div>
      <div class="q-list">
        <a class="q-row reveal" href="#">
          <span class="q-num">01</span>
          <div class="q-main">
            <h3>Is Minca worth the detour?</h3>
            <div class="q-en">"Is Minca worth it?"</div>
            <p>You've got two to four weeks for Colombia. Whether the jungle in the Sierra earns three of those days, in plain terms.</p>
          </div>
          <span class="q-go">Read <span class="arrow">&rarr;</span></span>
        </a>
        <a class="q-row reveal" href="#">
          <span class="q-num">02</span>
          <div class="q-main">
            <h3>How many days does Minca actually need?</h3>
            <div class="q-en">"How many days in Minca?"</div>
            <p>One day, three, or a slow week. What you can really see at each length, and what you'd be rushing.</p>
          </div>
          <span class="q-go">Read <span class="arrow">&rarr;</span></span>
        </a>
        <a class="q-row reveal" href="#">
          <span class="q-num">03</span>
          <div class="q-main">
            <h3>Minca or Tayrona, if you can only pick one.</h3>
            <div class="q-en">"Minca vs Tayrona"</div>
            <p>The most repeated dilemma on every forum: mountain versus beach, effort, crowds, atmosphere. Decided honestly.</p>
          </div>
          <span class="q-go">Read <span class="arrow">&rarr;</span></span>
        </a>
        <a class="q-row reveal" href="#">
          <span class="q-num">04</span>
          <div class="q-main">
            <h3>Where to stay in Minca if you came to rest.</h3>
            <div class="q-en">"Where to stay in Minca for relaxation"</div>
            <p>Not a list of every bed in town. The few places that match what you're actually looking for, and why.</p>
          </div>
          <span class="q-go">Read <span class="arrow">&rarr;</span></span>
        </a>
      </div>
    </div>
  </section>

  <section id="territorio" class="terr-sec">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">The wider coast</span>
        <h2>Minca first, properly. The rest of the coast as it's ready.</h2>
        <p class="lede">We'd rather cover one place with the depth of someone who lives there than thinly cover the whole coast. Minca is live now. These are next — built the same way, from the ground, never from a press kit.</p>
      </div>
      <Image
        src={burroTrafico}
        alt="A donkey crossing between motorbikes on the main street of Minca, Sierra Nevada de Santa Marta"
        class="terr-band reveal"
        width={1200}
        height={450}
        style="object-fit:cover;border-radius:4px;"
      />
      <div class="terr-grid">
        <a class="terr-cell live reveal" href="#preguntas">
          <div>
            <div class="place">Minca</div>
            <div class="desc">Jungle, coffee, waterfalls, the slow Sierra.</div>
          </div>
          <span class="state"><span class="sdot"></span><span>Live — 4 guides</span></span>
        </a>
        <div class="terr-cell soon reveal">
          <div>
            <div class="place">Santa Marta</div>
            <div class="desc">The gateway: where to base, what's safe, how to move.</div>
          </div>
          <span class="state"><span class="sdot"></span><span>In progress</span></span>
        </div>
        <div class="terr-cell soon reveal">
          <div>
            <div class="place">Tayrona</div>
            <div class="desc">Which entrance, which trail, when to go, where to sleep.</div>
          </div>
          <span class="state"><span class="sdot"></span><span>In progress</span></span>
        </div>
        <div class="terr-cell soon reveal">
          <div>
            <div class="place">Palomino</div>
            <div class="desc">The bohemian coast: swimming, tubing, what's overhyped.</div>
          </div>
          <span class="state"><span class="sdot"></span><span>Planned</span></span>
        </div>
        <div class="terr-cell soon reveal">
          <div>
            <div class="place">Cartagena</div>
            <div class="desc">The walled city without the tourist markup.</div>
          </div>
          <span class="state"><span class="sdot"></span><span>Planned</span></span>
        </div>
        <div class="terr-cell soon reveal">
          <div>
            <div class="place">La Guajira</div>
            <div class="desc">Desert meets sea: 4x4s, Wayúu communities, doing it right.</div>
          </div>
          <span class="state"><span class="sdot"></span><span>Planned</span></span>
        </div>
      </div>
    </div>
  </section>

  <section id="como" class="layers">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">Why this isn't another blog</span>
        <h2>Read freely. Buy nothing unless you want the whole map.</h2>
        <p class="lede">Most of what's here is open and free, on purpose. The point is to be useful before you've spent a peso — and to be the place the answer comes from when you ask anyone, human or machine.</p>
      </div>
      <div class="layer-grid">
        <div class="layer reveal">
          <span class="ln">01</span>
          <h3>The free answers</h3>
          <p>The guides above. They settle the questions well enough to be genuinely useful, and structured so the AI engines cite them instead of guessing. You lose nothing by reading.</p>
          <span class="tag">Always free</span>
        </div>
        <div class="layer reveal">
          <span class="ln">02</span>
          <h3>The full Minca brief</h3>
          <p>When the free guide isn't enough, the complete thing: the criteria, the trades and artisans nobody else lists, the itinerary already solved. What only someone living here can hand you.</p>
          <span class="tag">When you want the detail</span>
        </div>
        <div class="layer reveal">
          <span class="ln">03</span>
          <h3>Come stay, when it's time</h3>
          <p>The lodge, the experience by the river, the deeper letters. Never pushed in the reading — offered only once you already trust the judgment behind it.</p>
          <span class="tag">Entre Río y Fuego</span>
        </div>
      </div>
      <Image
        src={hornoLodge}
        alt="The wood-fired oven at Entre Río y Fuego lodge in Minca, Sierra Nevada de Santa Marta"
        class="lodge-img reveal"
        width={800}
        height={500}
        style="object-fit:cover;border-radius:4px;"
      />
    </div>
  </section>

  <section id="lista" class="list-sec">
    <div class="wrap">
      <div class="list-grid">
        <div class="reveal">
          <span class="eyebrow">The one thing worth your email</span>
          <h2 class="list-h2">A short letter from the Sierra, when there's something real to say.</h2>
          <p class="lede" style="color:var(--sombra)">No schedule, no filler, no selling. When the rivers change, when a place stops being worth it, when something opens that you'd actually want to know about — you hear it from someone who was there. That's the deal.</p>
        </div>
        <div class="list-card reveal">
          <label for="email">Get the Minca guides and the letters</label>
          <div class="field-row">
            <input id="email" type="email" inputmode="email" placeholder="you@email.com" autocomplete="email" aria-label="Your email">
            <button id="subscribe" type="button">Join</button>
          </div>
          <div class="list-msg" id="listmsg" role="status" aria-live="polite"></div>
          <p class="fine">First-hand, occasional, and yours to leave anytime. No partner gets this list.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer lang="en" />

  <script>
    // Formulario de suscripción
    const sub = document.getElementById('subscribe');
    const msg = document.getElementById('listmsg');
    const email = document.getElementById('email') as HTMLInputElement;

    function tryJoin() {
      const v = (email.value || '').trim();
      if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(v)) {
        if (msg) {
          msg.style.color = '#9B6B3A';
          msg.textContent = 'Add a valid email and you are in.';
        }
        return;
      }
      if (msg) {
        msg.style.color = '#3D5A3E';
        msg.textContent = 'You are on the list. First letter comes when there is something real to say.';
      }
      email.value = '';
    }

    if (sub) sub.addEventListener('click', tryJoin);
    if (email) email.addEventListener('keydown', (e) => { if (e.key === 'Enter') tryJoin(); });

    // Clics en q-row para evitar enlaces rotos (#)
    document.querySelectorAll('.q-row, .terr-cell.live').forEach(r => {
      r.addEventListener('click', (e) => {
        if (r.getAttribute('href') === '#') { e.preventDefault(); }
      });
    });

    // Intersection Observer para animaciones
    const prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if ('IntersectionObserver' in window && !prefersReduced) {
      document.documentElement.classList.add('js-anim');
      const io = new IntersectionObserver((entries) => {
        entries.forEach(en => {
          if (en.isIntersecting) {
            en.target.classList.add('in');
            io.unobserve(en.target);
          }
        });
      }, { threshold: 0.12 });
      document.querySelectorAll('.reveal').forEach(el => { io.observe(el); });
      setTimeout(() => {
        document.querySelectorAll('.reveal:not(.in)').forEach(el => { el.classList.add('in'); });
      }, 2500);
    }
  </script>
</Layout>
