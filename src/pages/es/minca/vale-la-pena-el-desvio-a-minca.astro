const title = "¿Vale la pena el desvío a Minca? — verybdn";
const description = "Una respuesta honesta y de primera mano sobre si Minca merece un lugar en tu itinerario por Colombia: lo que es cierto del centro saturado, los senderos de verdad, y quién paga cuando un lugar se vuelve 'descubierto'.";
